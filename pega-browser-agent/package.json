    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "pngjs": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.1",
